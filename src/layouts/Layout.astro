---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Precision cybersecurity prompts for AI assistants — tested, token-optimised, and ready to use.' } = Astro.props;
const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>

    <nav>
      <div class="nav-inner">
        <a href="/" class="logo" aria-label="SecureLayer home">
          <img src="/logo.svg" alt="" class="logo-img" />
          <span class="logo-text">Secure<span>Layer</span></span>
        </a>
        <div class="nav-links">
          <a href="/prompts" class:list={[{ active: currentPath === '/prompts' }]}>Free Prompts</a>
          <a href="/#pricing" class:list={[{ active: false }]}>Pricing</a>
          <a href="/#get-started" class="btn-nav">Get Started</a>
        </div>
      </div>
    </nav>

    <slot />

    <footer>
      <div class="footer-inner">
        <a href="/" class="logo">Secure<span>Layer</span></a>
        <p>Precision cybersecurity prompts — tested, optimised, and ready to use.</p>
        <p class="footer-copy">&copy; {new Date().getFullYear()} SecureLayer. All rights reserved.</p>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #080c14;
    --bg2: #0d1320;
    --bg3: #111827;
    --border: rgba(99,179,237,0.12);
    --border2: rgba(255,255,255,0.06);
    --cyan: #38bdf8;
    --cyan-dim: rgba(56,189,248,0.12);
    --green: #22c55e;
    --purple: #a78bfa;
    --text: #e2e8f0;
    --muted: #94a3b8;
    --white: #f8fafc;
    --radius: 16px;
    --font: 'Inter', sans-serif;
    --font-head: 'Space Grotesk', sans-serif;
    --font-mono: 'JetBrains Mono', 'Courier New', monospace;
  }

  html { scroll-behavior: smooth; }
  body { background: var(--bg); color: var(--text); font-family: var(--font); line-height: 1.6; -webkit-font-smoothing: antialiased; }

  /* NAV */
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(8,12,20,0.88); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); }
  .nav-inner { max-width: 1100px; margin: 0 auto; padding: 0 24px; height: 64px; display: flex; align-items: center; justify-content: space-between; }
  .logo { display: inline-flex; align-items: center; gap: 10px; text-decoration: none; }
  .logo-img { height: 32px; width: 32px; filter: brightness(0) invert(1); flex-shrink: 0; }
  .logo-text { font-family: var(--font-head); font-size: 1.25rem; font-weight: 700; color: var(--white); }
  .logo-text span { color: var(--cyan); }
  .nav-links { display: flex; align-items: center; gap: 28px; }
  .nav-links a:not(.btn-nav) { color: var(--muted); text-decoration: none; font-size: 0.875rem; transition: color 0.2s; }
  .nav-links a:not(.btn-nav):hover, .nav-links a.active { color: var(--text); }
  .btn-nav { background: var(--cyan-dim); border: 1px solid rgba(56,189,248,0.3); color: var(--cyan); padding: 8px 20px; border-radius: 8px; font-size: 0.875rem; font-weight: 500; text-decoration: none; transition: background 0.2s; }
  .btn-nav:hover { background: rgba(56,189,248,0.22); }

  /* SHARED TYPOGRAPHY */
  .section-label { font-size: 0.7rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cyan); margin-bottom: 16px; }
  h2 { font-family: var(--font-head); font-size: clamp(1.5rem, 3.5vw, 2.2rem); font-weight: 700; color: var(--white); margin-bottom: 16px; }
  .section-sub { color: var(--muted); max-width: 560px; margin: 0 auto 60px; }

  /* SHARED PROMPT CARD */
  .prompt-card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; }
  .prompt-header { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 12px; padding: 16px 20px; border-bottom: 1px solid var(--border); background: var(--bg3); }
  .prompt-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
  .badge-tier { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 10px; border-radius: 100px; }
  .badge-tier.free { background: rgba(34,197,94,0.12); color: var(--green); border: 1px solid rgba(34,197,94,0.2); }
  .badge-tested { display: inline-flex; align-items: center; gap: 4px; font-size: 0.72rem; color: var(--green); font-weight: 500; }
  .badge-tokens { font-size: 0.72rem; color: var(--muted); background: var(--bg); border: 1px solid var(--border2); padding: 2px 8px; border-radius: 6px; }
  .badge-cat { font-size: 0.72rem; color: var(--cyan); background: var(--cyan-dim); border: 1px solid rgba(56,189,248,0.15); padding: 2px 8px; border-radius: 6px; }
  .badge-expertise { font-size: 0.72rem; color: var(--purple); background: rgba(167,139,250,0.08); border: 1px solid rgba(167,139,250,0.15); padding: 2px 8px; border-radius: 6px; }
  .btn-copy { display: inline-flex; align-items: center; gap: 6px; background: var(--cyan-dim); border: 1px solid rgba(56,189,248,0.25); color: var(--cyan); font-size: 0.8rem; font-weight: 500; padding: 7px 14px; border-radius: 8px; cursor: pointer; transition: background 0.2s; font-family: var(--font); white-space: nowrap; }
  .btn-copy:hover { background: rgba(56,189,248,0.2); }
  .prompt-title { font-family: var(--font-head); font-size: 1.05rem; color: var(--white); padding: 20px 20px 12px; }
  .prompt-tags { display: flex; gap: 6px; flex-wrap: wrap; padding: 0 20px 16px; }
  .tag { font-size: 0.68rem; color: var(--muted); background: var(--bg3); border: 1px solid var(--border2); padding: 2px 8px; border-radius: 4px; }
  .prompt-body { font-family: var(--font-mono); font-size: 0.8rem; line-height: 1.7; color: #cbd5e1; background: #0a0f1a; padding: 20px; overflow-x: auto; white-space: pre-wrap; word-break: break-word; border-top: 1px solid var(--border); }
  .prompt-tested-note { font-size: 0.75rem; color: var(--muted); padding: 12px 20px; border-top: 1px solid var(--border); background: var(--bg3); }

  /* FOOTER */
  footer { border-top: 1px solid var(--border); padding: 48px 24px; text-align: center; }
  .footer-inner { max-width: 1100px; margin: 0 auto; }
  .footer-inner .logo { display: inline-block; margin-bottom: 12px; }
  .footer-inner p { color: var(--muted); font-size: 0.875rem; }
  .footer-copy { margin-top: 24px; font-size: 0.75rem; }

  @media (max-width: 640px) {
    .nav-links a:not(.btn-nav) { display: none; }
    .prompt-header { flex-direction: column; align-items: flex-start; }
  }
</style>

<script>
  document.querySelectorAll('.btn-copy').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.getAttribute('data-prompt-id');
      const pre = document.getElementById(`prompt-${id}`);
      if (!pre) return;
      try {
        await navigator.clipboard.writeText(pre.textContent ?? '');
        const orig = btn.innerHTML;
        btn.innerHTML = `<svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8l4 4 6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg> Copied!`;
        btn.style.color = '#22c55e';
        setTimeout(() => { btn.innerHTML = orig; btn.style.color = ''; }, 2000);
      } catch {
        btn.textContent = 'Copy failed';
      }
    });
  });
</script>
